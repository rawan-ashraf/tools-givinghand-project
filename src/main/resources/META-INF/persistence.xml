<persistence xmlns="https://jakarta.ee/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="https://jakarta.ee/xml/ns/persistence
             https://jakarta.ee/xml/ns/persistence/persistence_3_0.xsd"
             version="3.0">

    <persistence-unit name="givingHandPU" transaction-type="JTA">
        <jta-data-source>java:jboss/datasources/ExampleDS</jta-data-source>

        <class>com.example.givinghand.entity.user</class>
        <class>com.example.givinghand.entity.Campaign</class>
        <class>com.example.givinghand.entity.CampaignNeedItem</class>
        <class>com.example.givinghand.entity.Donation</class>
        <class>com.example.givinghand.entity.DonationLog</class>
        <class>com.example.givinghand.entity.Notification</class>
        <class>com.example.givinghand.entity.Warehouse</class>
        <class>com.example.givinghand.entity.WarehouseItem</class>

        <exclude-unlisted-classes>true</exclude-unlisted-classes>

        <properties>
            <property name="jakarta.persistence.schema-generation.database.action" value="drop-and-create"/>
            <property name="hibernate.show_sql" value="true"/>
            <property name="hibernate.format_sql" value="true"/>
        </properties>
    </persistence-unit>

</persistence>